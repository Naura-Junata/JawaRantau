/**
 * Konfigurasi Firebase
 */
const FIREBASE_CONFIG = typeof window.__firebase_config !== 'undefined' 
  ? JSON.parse(window.__firebase_config) 
  : {};

/**
 * Achievement badges configuration
 */
const BADGES = {
  PEMULA: 'Pemula',
  WONG_JAWA_LUWES: 'Wong Jowo Luwes',
  WONG_JAWA_SEJATI: 'Wong Jowo Sejati'
};

const BADGE_REQUIREMENTS = {
  [BADGES.WONG_JAWA_LUWES]: 100,
  [BADGES.WONG_JAWA_SEJATI]: 300
};

const QUIZ_PASSING_SCORE = 0.7; // 70%
const XP_PER_QUESTION = 10;

// ============================================
// 4. FIREBASE INITIALIZATION
// ============================================
const app = initializeApp(FIREBASE_CONFIG);
const auth = getAuth(app);
const db = getFirestore(app);

// Clean appId untuk Firestore path
const rawAppId = typeof window.__app_id !== 'undefined' ? window.__app_id : 'jawa-rantau-app';
const CLEAN_APP_ID = rawAppId.replace(/[^a-zA-Z0-9]/g, '_');

// ============================================
// 5. MAIN COMPONENT
// ============================================
export default function App() {
  // ==========================================
  // 5.1 STATE MANAGEMENT
  // ==========================================
  const [user, setUser] = useState(null);
  const [userData, setUserData] = useState({
    xp: 0,
    streak: 0,
    level: 1,
    badges: [],
    name: ''
  });
  const [isLoading, setIsLoading] = useState(true);
  const [currentView, setCurrentView] = useState('auth'); // auth, home, lesson, quiz, result
  const [currentEpisode, setCurrentEpisode] = useState(null);
  const [quizState, setQuizState] = useState({
    currentIndex: 0,
    score: 0,
    showFeedback: false,
    isCorrect: false,
    selectedOptionIndex: null
  });
  
  const nameInputRef = useRef(null);

  // ==========================================
  // 5.2 AUTHENTICATION EFFECTS
  // ==========================================
  useEffect(() => {
    initializeAuth();
    
    const unsubscribe = onAuthStateChanged(auth, handleAuthStateChange);
    return () => unsubscribe();
  }, []);

  const initializeAuth = async () => {
    try {
      if (typeof window.__initial_auth_token !== 'undefined' && window.__initial_auth_token) {
        await signInWithCustomToken(auth, window.__initial_auth_token);
      } else {
        await signInAnonymously(auth);
      }
    } catch (error) {
      console.error("Authentication Error:", error);
    }
  };

  const handleAuthStateChange = (authenticatedUser) => {
    setUser(authenticatedUser);
    setIsLoading(false);
  };

  // ==========================================
  // 5.3 FIRESTORE SYNC EFFECT
  // ==========================================
  useEffect(() => {
    if (!user) return;

    const userProfileRef = doc(db, 'artifacts', CLEAN_APP_ID, 'users', user.uid, 'profile');
    
    const unsubscribe = onSnapshot(userProfileRef, 
      (documentSnapshot) => handleProfileSnapshot(documentSnapshot),
      (error) => console.error("Firestore Snapshot Error:", error)
    );

    return () => unsubscribe();
  }, [user]);

  const handleProfileSnapshot = (documentSnapshot) => {
    if (documentSnapshot.exists()) {
      const data = documentSnapshot.data();
      setUserData(data);
      
      if (data.name && currentView === 'auth') {
        setCurrentView('home');
      }
    } else {
      initializeUserProfile();
    }
  };

  const initializeUserProfile = async () => {
    if (!user) return;
    
    const userProfileRef = doc(db, 'artifacts', CLEAN_APP_ID, 'users', user.uid, 'profile');
    await setDoc(userProfileRef, {
      xp: 0,
      streak: 1,
      level: 1,
      badges: [BADGES.PEMULA],
      name: ''
    }, { merge: true });
  };

  // ==========================================
  // 5.4 USER ACTION HANDLERS
  // ==========================================
  
  /**
   * Menyimpan nama user ke database
   */
  const handleSaveName = async () => {
    const nameValue = nameInputRef.current?.value;
    if (!nameValue || !nameValue.trim() || !user) return;

    const userProfileRef = doc(db, 'artifacts', CLEAN_APP_ID, 'users', user.uid, 'profile');
    await setDoc(userProfileRef, { 
      ...userData, 
      name: nameValue.trim() 
    }, { merge: true });
    
    setCurrentView('home');
  };

  /**
   * Memulai episode pembelajaran
   */
  const handleStartEpisode = (episodeId) => {
    const episode = LEARNING_EPISODES.find(e => e.id === episodeId);
    setCurrentEpisode(episode);
    setCurrentView('lesson');
  };

  /**
   * Memulai kuis
   */
  const handleStartQuiz = () => {
    setQuizState({
      currentIndex: 0,
      score: 0,
      showFeedback: false,
      isCorrect: false,
      selectedOptionIndex: null
    });
    setCurrentView('quiz');
  };

  /**
   * Menangani jawaban kuis
   */
  const handleAnswerSubmit = (optionIndex) => {
    if (quizState.showFeedback) return;
    
    const currentQuiz = currentEpisode.quizzes[quizState.currentIndex];
    const isAnswerCorrect = optionIndex === currentQuiz.correctAnswerIndex;
    
    setQuizState(prev => ({
      ...prev,
      showFeedback: true,
      isCorrect: isAnswerCorrect,
      selectedOptionIndex: optionIndex,
      score: isAnswerCorrect ? prev.score + XP_PER_QUESTION : prev.score
    }));

    setTimeout(() => {
      if (quizState.currentIndex < currentEpisode.quizzes.length - 1) {
        // Lanjut ke soal berikutnya
        setQuizState(prev => ({
          ...prev,
          currentIndex: prev.currentIndex + 1,
          showFeedback: false,
          selectedOptionIndex: null
        }));
      } else {
        // Kuis selesai
        finishQuiz(isAnswerCorrect ? quizState.score + XP_PER_QUESTION : quizState.score);
      }
    }, 1500);
  };

  /**
   * Menyelesaikan kuis dan update progress user
   */
  const finishQuiz = async (finalScore) => {
    const totalPossiblePoints = currentEpisode.quizzes.length * XP_PER_QUESTION;
    const isPassed = (finalScore / totalPossiblePoints) >= QUIZ_PASSING_SCORE;
    
    if (isPassed && user) {
      await updateUserProgress(finalScore);
    }
    
    setCurrentView('result');
  };

  /**
   * Update user progress di Firestore
   */
  const updateUserProgress = async (earnedXP) => {
    const newLevel = Math.max(
      userData.level, 
      Math.min(currentEpisode.id + 1, LEARNING_EPISODES.length + 1)
    );
    const newTotalXP = userData.xp + earnedXP;
    const newBadges = [...userData.badges];

    // Cek pencapaian badge
    if (newTotalXP >= BADGE_REQUIREMENTS[BADGES.WONG_JAWA_LUWES] && 
        !newBadges.includes(BADGES.WONG_JAWA_LUWES)) {
      newBadges.push(BADGES.WONG_JAWA_LUWES);
    }
    if (newTotalXP >= BADGE_REQUIREMENTS[BADGES.WONG_JAWA_SEJATI] && 
        !newBadges.includes(BADGES.WONG_JAWA_SEJATI)) {
      newBadges.push(BADGES.WONG_JAWA_SEJATI);
    }

    const userProfileRef = doc(db, 'artifacts', CLEAN_APP_ID, 'users', user.uid, 'profile');
    await setDoc(userProfileRef, { 
      ...userData, 
      xp: newTotalXP, 
      level: newLevel,
      badges: Array.from(new Set(newBadges))
    }, { merge: true });
  };

  /**
   * Kembali ke halaman utama
   */
  const handleBackToHome = () => {
    setCurrentView('home');
  };

  // ==========================================
  // 5.5 RENDER HELPERS
  // ==========================================
  
  if (isLoading) {
    return <LoadingScreen />;
  }

  // ==========================================
  // 5.6 RENDER VIEWS
  // ==========================================
  return (
    <div className="min-h-screen bg-[#f4ecd8] text-[#4a3018] font-sans selection:bg-amber-300">
      
      {/* Header - Hanya tampil jika bukan halaman auth */}
      {currentView !== 'auth' && (
        <AppHeader 
          userName={userData.name}
          streak={userData.streak}
          xp={userData.xp}
          onHomeClick={handleBackToHome}
        />
      )}

      <main className="max-w-md mx-auto p-4 pb-24">
        {currentView === 'auth' && (
          <AuthScreen 
            nameInputRef={nameInputRef}
            onSaveName={handleSaveName}
          />
        )}

        {currentView === 'home' && (
          <HomeScreen 
            userName={userData.name}
            userBadges={userData.badges}
            userLevel={userData.level}
            episodes={LEARNING_EPISODES}
            onStartEpisode={handleStartEpisode}
          />
        )}

        {currentView === 'lesson' && currentEpisode && (
          <LessonScreen 
            episode={currentEpisode}
            onBack={handleBackToHome}
            onStartQuiz={handleStartQuiz}
          />
        )}

        {currentView === 'quiz' && currentEpisode && (
          <QuizScreen 
            episode={currentEpisode}
            quizState={quizState}
            onAnswer={handleAnswerSubmit}
            onBack={() => setCurrentView('lesson')}
          />
        )}

        {currentView === 'result' && (
          <ResultScreen 
            userData={userData}
            onBackToHome={handleBackToHome}
          />
        )}
      </main>

      {/* Bottom Navigation - Hanya di halaman home */}
      {currentView === 'home' && <BottomNavigation />}

      {/* Global Styles & Animations */}
      <GlobalStyles />
    </div>
  );
}

// ============================================
// 6. COMPONENT: Loading Screen
// ============================================
const LoadingScreen = () => (
  <div className="min-h-screen flex flex-col items-center justify-center bg-[#f4ecd8] text-[#5c3a21]">
    <div className="w-12 h-12 border-4 border-[#5c3a21] border-t-transparent rounded-full animate-spin mb-4"></div>
    <p className="font-bold">Sabar sek, lagi loading...</p>
  </div>
);

// ============================================
// 7. COMPONENT: App Header
// ============================================
const AppHeader = ({ userName, streak, xp, onHomeClick }) => (
  <header className="bg-[#5c3a21] text-amber-50 p-4 shadow-md sticky top-0 z-10">
    <div className="max-w-md mx-auto flex justify-between items-center">
      <h1 
        className="font-bold text-xl flex items-center gap-2 cursor-pointer" 
        onClick={onHomeClick}
      >
        JawaRantau
      </h1>
      <div className="flex gap-4 items-center text-sm font-semibold">
        <div className="flex items-center gap-1 text-orange-300">
          <Flame size={18} fill="currentColor" /> {streak || 0}
        </div>
        <div className="flex items-center gap-1 text-yellow-400">
          <Star size={18} fill="currentColor" /> {xp || 0}
        </div>
        <div className="bg-amber-700 p-1.5 rounded-full">
          <User size={18} />
        </div>
      </div>
    </div>
  </header>
);

// ============================================
// 8. COMPONENT: Auth Screen
// ============================================
const AuthScreen = ({ nameInputRef, onSaveName }) => (
  <div className="flex flex-col items-center justify-center min-h-[75vh] text-center px-4 animate-fade-in">
    <div className="w-24 h-24 bg-[#5c3a21] text-amber-50 rounded-full flex items-center justify-center mb-6 shadow-xl">
      <BookOpen size={48} />
    </div>
    <h1 className="text-3xl font-extrabold mb-2 text-[#5c3a21]">Sugeng Rawuh!</h1>
    <p className="mb-8 text-amber-800">
      Ayo sinau basa Jawa supaya luwih akrab karo kanca-kanca neng tanah Jawa.
    </p>
    
    <div className="w-full max-w-xs space-y-4 bg-white p-6 rounded-2xl shadow-md border border-amber-200">
      <div className="text-left">
        <label className="block font-bold text-sm text-amber-900 mb-2">
          Sapa jenengmu? (Siapa namamu?)
        </label>
        <input 
          ref={nameInputRef}
          type="text" 
          placeholder="Ketik jeneng neng kene..." 
          className="w-full p-3 border-2 border-amber-100 rounded-xl focus:outline-none focus:border-[#5c3a21] bg-amber-50 transition-colors"
          onKeyDown={(e) => e.key === 'Enter' && onSaveName()}
        />
      </div>
      <button 
        onClick={onSaveName}
        className="w-full bg-[#5c3a21] text-white font-bold py-3.5 rounded-xl hover:bg-[#4a3018] transition shadow-lg active:scale-95"
      >
        Mulai Sinau
      </button>
    </div>
  </div>
);

// ============================================
// 9. COMPONENT: Home Screen
// ============================================
const HomeScreen = ({ userName, userBadges, userLevel, episodes, onStartEpisode }) => (
  <div className="animate-fade-in space-y-6">
    {/* Welcome Card */}
    <div className="bg-gradient-to-br from-[#5c3a21] to-amber-900 p-6 rounded-2xl text-amber-50 shadow-xl relative overflow-hidden">
      <div className="relative z-10">
        <h2 className="text-xl font-bold mb-1">Sugeng, {userName || 'Sobat'}! 👋</h2>
        <p className="text-amber-200 text-sm">Wis siap lanjut sinau dino iki?</p>
        <div className="mt-4 flex gap-2 flex-wrap">
          {userBadges && userBadges.map((badge, index) => (
            <Badge key={index} label={badge} />
          ))}
        </div>
      </div>
      <div className="absolute -right-4 -bottom-4 opacity-10 rotate-12">
        <BookOpen size={120} />
      </div>
    </div>

    {/* Episodes List */}
    <div className="space-y-4">
      <h3 className="font-bold text-lg text-[#5c3a21] flex items-center gap-2 px-2">
        <BookOpen size={20} className="text-amber-700" /> Tingkat Ngoko (Dasar)
      </h3>
      
      <div className="relative px-2">
        {/* Timeline Line */}
        <div className="absolute left-[2.4rem] top-8 bottom-8 w-1.5 bg-amber-100/50 z-0"></div>

        {episodes.map((episode) => {
          const isLocked = episode.id > userLevel;
          const isCurrent = episode.id === userLevel;
          const isCompleted = episode.id < userLevel;

          return (
            <EpisodeItem
              key={episode.id}
              episode={episode}
              isLocked={isLocked}
              isCurrent={isCurrent}
              isCompleted={isCompleted}
              onStart={onStartEpisode}
            />
          );
        })}
      </div>
    </div>
  </div>
);

// ============================================
// 10. COMPONENT: Badge
// ============================================
const Badge = ({ label }) => (
  <span className="text-[10px] uppercase tracking-wider bg-white/10 px-2.5 py-1 rounded-full border border-white/20 flex items-center gap-1 font-bold">
    <Award size={12} className="text-yellow-400"/> {label}
  </span>
);

// ============================================
// 11. COMPONENT: Episode Item
// ============================================
const EpisodeItem = ({ episode, isLocked, isCurrent, isCompleted, onStart }) => (
  <div className="relative z-10 flex items-start gap-5 mb-8 last:mb-0">
    {/* Episode Number / Status */}
    <div className={`
      w-14 h-14 rounded-2xl flex items-center justify-center border-4 shadow-sm shrink-0 
      transition-all duration-300
      ${isCurrent ? 'scale-110 rotate-3 ring-4 ring-amber-200' : ''}
      ${isLocked 
        ? 'bg-amber-50 border-amber-100 text-amber-200' 
        : isCompleted 
          ? 'bg-yellow-400 border-yellow-500 text-white' 
          : 'bg-[#5c3a21] border-[#4a3018] text-white'
      }
    `}>
      {isCompleted ? (
        <CheckCircle2 size={28} />
      ) : (
        <span className="text-xl font-black">{episode.id}</span>
      )}
    </div>
    
    {/* Episode Card */}
    <div className={`

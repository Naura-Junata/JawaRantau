);

// ============================================
// 17. COMPONENT: Quiz Screen
// ============================================
const QuizScreen = ({ episode, quizState, onAnswer, onBack }) => {
  const currentQuiz = episode.quizzes[quizState.currentIndex];
  const progressPercentage = ((quizState.currentIndex) / episode.quizzes.length) * 100;

  return (
    <div className="animate-fade-in flex flex-col min-h-[75vh]">
      {/* Progress Bar */}
      <div className="flex items-center gap-4 mb-8">
        <button 
          onClick={onBack} 
          className="text-amber-700/50 hover:text-amber-700 transition-colors"
        >
          <XCircle size={28} />
        </button>
        <div className="flex-1 bg-amber-200/50 h-3.5 rounded-full overflow-hidden border border-amber-200">
          <div 
            className="bg-green-500 h-full transition-all duration-500 ease-out" 
            style={{ width: `${progressPercentage}%` }}
          ></div>
        </div>
      </div>

      {/* Question */}
      <div className="flex-1 flex flex-col justify-center px-2">
        <div className="bg-white p-8 rounded-[2.5rem] shadow-xl border border-amber-100 mb-10 relative">
          <div className="absolute -top-4 left-10 bg-amber-700 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">
            Pitakon {quizState.currentIndex + 1}
          </div>
          <h2 className="text-xl font-bold text-[#5c3a21] leading-relaxed whitespace-pre-line text-center">
            {currentQuiz.question}
          </h2>
        </div>

        {/* Options */}
        <div className="grid gap-3">
          {currentQuiz.options.map((option, index) => (
            <QuizOption
              key={index}
              index={index}
              option={option}
              isSelected={quizState.selectedOptionIndex === index}
              isCorrect={index === currentQuiz.correctAnswerIndex}
              showFeedback={quizState.showFeedback}
              onSelect={onAnswer}
            />
          ))}
        </div>
      </div>

      {/* Feedback Overlay */}
      {quizState.showFeedback && (
        <QuizFeedback 
          isCorrect={quizState.isCorrect}
          earnedXP={XP_PER_QUESTION}
        />
      )}
    </div>
  );
};

// ============================================
// 18. COMPONENT: Quiz Option
// ============================================
const QuizOption = ({ index, option, isSelected, isCorrect, showFeedback, onSelect }) => {
  let buttonStyle = "w-full text-left p-5 rounded-2xl border-2 font-bold transition-all duration-200 ";
  
  if (showFeedback) {
    if (isCorrect) {
      buttonStyle += "bg-green-100 border-green-500 text-green-800 scale-[1.02] shadow-md";
    } else if (isSelected) {
      buttonStyle += "bg-red-100 border-red-500 text-red-800 scale-[0.98]";
    } else {
      buttonStyle += "bg-white border-amber-50 text-amber-200 opacity-40";
    }
  } else {
    buttonStyle += "bg-white border-amber-100 text-amber-900 hover:border-[#5c3a21] hover:bg-amber-50 active:scale-[0.97] shadow-sm";
  }

  return (
    <button 
      disabled={showFeedback}
      onClick={() => onSelect(index)}
      className={buttonStyle}
    >
      <div className="flex items-center gap-4">
        <div className={`
          w-8 h-8 rounded-lg flex items-center justify-center text-xs border
          ${showFeedback && isCorrect ? 'bg-green-500 border-green-600 text-white' : 'bg-amber-50 border-amber-200'}
        `}>
          {String.fromCharCode(65 + index)}
        </div>
        {option}
      </div>
    </button>
  );
};

// ============================================
// 19. COMPONENT: Quiz Feedback
// ============================================
const QuizFeedback = ({ isCorrect, earnedXP }) => (
  <div className={`
    fixed bottom-0 left-0 right-0 p-8 rounded-t-[3rem] shadow-2xl animate-slide-up 
    flex justify-between items-center z-50
    ${isCorrect ? 'bg-green-500 text-white' : 'bg-red-500 text-white'}
  `}>
    <div className="flex items-center gap-4">
      <div className="bg-white/20 p-3 rounded-full">
        {isCorrect ? <CheckCircle2 size={32} /> : <XCircle size={32} />}
      </div>
      <div>
        <h3 className="text-xl font-black">
          {isCorrect ? 'Jos Banget!' : 'Salah Sitik...'}
        </h3>
        <p className="text-xs opacity-90 font-bold">
          {isCorrect ? `Oleh +${earnedXP} XP` : 'Ayo fokus maneh!'}
        </p>
      </div>
    </div>
  </div>
);

